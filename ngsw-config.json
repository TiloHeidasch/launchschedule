{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(eot|svg|cur|jpg|png|webp|gif|otf|ttf|woff|woff2|ani)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "LaunchLibrary",
      "urls": [
        "https://ll.thespacedevs.com/2.3.0/agencies",
        "https://ll.thespacedevs.com/2.3.0/astronauts",
        "https://ll.thespacedevs.com/2.3.0/dashboard/starship",
        "https://ll.thespacedevs.com/2.3.0/events",
        "https://ll.thespacedevs.com/2.3.0/launches/upcoming",
        "https://ll.thespacedevs.com/2.3.0/launches/previous",
        "https://ll.thespacedevs.com/2.3.0/locations",
        "https://ll.thespacedevs.com/2.3.0/pads",
        "https://ll.thespacedevs.com/2.3.0/launcher_configurations",
        "https://ll.thespacedevs.com/2.3.0/spacecraft_configurations",
        "https://ll.thespacedevs.com/2.3.0/space_stations"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "1h"
      }
    },
    {
      "name": "SNAPI",
      "urls": [
        "https://api.spaceflightnewsapi.net/v4/articles",
        "https://api.spaceflightnewsapi.net/v4/blogs",
        "https://api.spaceflightnewsapi.net/v4/reports"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 20,
        "maxAge": "1h"
      }
    },
    {
      "name": "Notifications",
      "urls": [
        "https://launchschedule-notifications.th105.de/notification/amount"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 20,
        "maxAge": "1d"
      }
    },
    {
      "name": "NASA",
      "urls": [
        "https://api.nasa.gov/planetary/apod",
        "https://epic.gsfc.nasa.gov/archive/natural/",
        "https://epic.gsfc.nasa.gov/api/natural",
        "https://api.nasa.gov/mars-photos/api/v1/rovers",
        "https://api.nasa.gov/mars-photos/api/v1/manifests"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 20,
        "maxAge": "1d"
      }
    }
  ]
}
